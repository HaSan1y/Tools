{
  "manifest_version": 3,
  "name": "YT Playlist Manager",
  "version": "1.0.0",
  "description": "Backup and export your playlists for YouTube safely and locally.",
  "permissions": [
    "activeTab",
    "scripting",
    "downloads",
    "storage"
  ],
  "host_permissions": [
    "https://www.youtube.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "YT Playlist Manager"
  },
  "icons": {
    "16": "icons/16x16.png",
    "48": "icons/48x48.png",
    "128": "icons/128x128.png"
  },
  "background": {
    "service_worker": "utils.js"
  }
}