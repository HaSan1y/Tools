{
  "manifest_version": 2,
  "name": "Page Watcher FF",
  "version": "1.0",
  "description": "Notify when a webpage changes",
  "permissions": [
    "storage",
    "notifications",
    "alarms",
    "<all_urls>"
  ],
  "background": {
    "scripts": [
      "background.js"
    ]
  },
  "browser_action": {
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "icons/16x16.png",
    "48": "icons/48x48.png",
    "128": "icons/128x128.png"
  }
}