{
  "manifest_version": 3,
  "name": "Translate to CSV",
  "version": "1.0",
  "description": "Convert text into sentence-by-sentence translations and export as CSV.",
  "action": {
    "default_popup": "popup.html"
  },
  "permissions": [],
  "host_permissions": [
    "https://api-free.deepl.com/*"
  ],
  "icons": {
    "16": "icons/16x16.png",
    "48": "icons/48x48.png",
    "128": "icons/128x128.png"
  }
}