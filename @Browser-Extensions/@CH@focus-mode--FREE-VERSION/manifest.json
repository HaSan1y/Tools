{
  "manifest_version": 3,
  "name": "Focus Mode",
  "version": "1.0",
  "description": "Clean any website and focus on what matters",
  "permissions": ["activeTab", "scripting"],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}